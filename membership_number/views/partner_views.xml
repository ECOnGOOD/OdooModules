<odoo>
    <record id="view_partner_form_inherit_ngo_number" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.ngo.number</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="membership.view_partner_form_default_membership"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='membership']" position="inside">
                <group string="Association Identity" name="ngo_numbers">
                    <field name="association_member_number"/>
                    <field name="all_membership_numbers_display" readonly="1" decoration-bf="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_membership_members_tree_inherit_ngo" model="ir.ui.view">
        <field name="name">membership.members.tree.inherit.ngo</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="membership.membership_members_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="before">
                <field name="association_member_number" optional="show"/>
            </field>
        </field>
    </record>
</odoo>