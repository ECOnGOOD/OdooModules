<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="1">
    <record id="ir_cron_membership_renewal" model="ir.cron">
        <field name="name">Membership Renewal</field>
        <field name="model_id" ref="model_membership_membership" />
        <field name="state">code</field>
        <field name="code">model.cron_generate_membership_renewals()</field>
        <field name="interval_number">12</field>
        <field name="interval_type">months</field>
        <field name="nextcall">2026-11-15 02:00:00</field>
        <field name="user_id" ref="base.user_root" />
        <field name="active">True</field>
    </record>

    <record id="ir_cron_membership_termination" model="ir.cron">
        <field name="name">Membership Termination</field>
        <field name="model_id" ref="model_membership_membership" />
        <field name="state">code</field>
        <field name="code">model.cron_terminate_expired_memberships()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall">2026-04-03 02:15:00</field>
        <field name="user_id" ref="base.user_root" />
        <field name="active">True</field>
    </record>
</odoo>
