<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_membership_renewal_wizard_form" model="ir.ui.view">
        <field name="name">membership.renewal.wizard.form</field>
        <field name="model">membership.renewal.wizard</field>
        <field name="arch" type="xml">
            <form string="Run Renewal">
                <group>
                    <group>
                        <field name="target_year" />
                        <field name="company_ids" widget="many2many_tags" />
                        <field
                            name="product_ids"
                            widget="many2many_tags"
                            domain="[('is_membership_product', '=', True)]"
                        />
                    </group>
                    <group>
                        <field name="dry_run" />
                        <field name="invoice_date" />
                        <field name="auto_post" />
                    </group>
                </group>
                <field name="result_line_ids" readonly="1">
                    <list create="0" edit="0" delete="0">
                        <field name="membership_id" />
                        <field name="partner_id" />
                        <field name="company_id" />
                        <field name="status" />
                        <field name="is_free" />
                        <field name="amount_expected" />
                        <field name="invoice_id" />
                        <field name="message" />
                    </list>
                </field>
                <footer>
                    <button name="action_run" string="Run" type="object" class="btn-primary" />
                    <button string="Close" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_membership_renewal_wizard" model="ir.actions.act_window">
        <field name="name">Renewal</field>
        <field name="res_model">membership.renewal.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="association_membership.view_membership_renewal_wizard_form" />
        <field name="target">new</field>
    </record>
</odoo>
