<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_res_config_settings_membership" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.membership</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Membership" name="association_membership" groups="association_membership.group_membership_manager">
                    <block title="Membership">
                        <setting string="Membership Product Category">
                            <field name="membership_product_category_id" />
                        </setting>
                        <setting string="Auto-activate on Payment">
                            <field name="membership_auto_activate_on_payment" />
                        </setting>
                        <setting string="Default Contribution Year">
                            <field name="membership_default_contribution_year_text" />
                        </setting>
                        <setting string="Invoicing Strategy">
                            <field name="membership_invoicing_strategy" />
                        </setting>
                    </block>
                    <block title="Communications">
                        <setting string="Activation Invoice Email Template">
                            <field
                                name="membership_activation_invoice_template_id"
                                domain="[('model', '=', 'account.move')]"
                            />
                        </setting>
                        <setting string="Cancellation Email Template">
                            <field
                                name="membership_cancellation_template_id"
                                domain="[('model', '=', 'membership.membership')]"
                            />
                        </setting>
                        <setting string="Membership Receipt Email Template">
                            <field
                                name="membership_membership_receipt_template_id"
                                domain="[('model', '=', 'membership.contribution')]"
                            />
                        </setting>
                        <setting string="Donation Receipt Email Template">
                            <field
                                name="membership_donation_receipt_template_id"
                                domain="[('model', '=', 'membership.contribution')]"
                            />
                        </setting>
                    </block>
                    <block title="Member Numbers">
                        <setting string="Member Number Prefix">
                            <field name="member_number_prefix" />
                        </setting>
                        <setting string="Member Number Padding">
                            <field name="member_number_padding" />
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_membership_settings" model="ir.actions.act_window">
        <field name="name">Membership Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'module': 'association_membership'}</field>
    </record>
</odoo>
