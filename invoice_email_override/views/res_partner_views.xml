<odoo>
    <record id="view_partner_form_invoice_email_override" model="ir.ui.view">
        <field name="name">res.partner.form.invoice.email.override</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='email']" position="after">
                <field name="invoice_email" widget="email" invisible="not is_company"/>
            </xpath>
        </field>
    </record>
</odoo>

