<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_company_form_membership_contract_glue" model="ir.ui.view">
        <field name="name">res.company.form.membership.contract.glue</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form" />
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Membership Contracts">
                    <field name="membership_contract_yearly_defaults" />
                </group>
            </xpath>
        </field>
    </record>
</odoo>
