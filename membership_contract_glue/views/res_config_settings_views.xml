<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record
        id="res_config_settings_view_form_membership_contract_glue"
        model="ir.ui.view"
    >
        <field name="name">res.config.settings.membership.contract.glue</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app
                    string="Membership"
                    name="membership_contract_glue"
                    data-key="membership_contract_glue"
                >
                    <block title="Membership Contracts">
                        <setting
                            id="membership_contract_dec31_default_setting"
                            string="Default membership end date"
                            help="Default new membership contract lines to December 31 of the start year."
                        >
                            <field name="membership_contract_dec31_default" />
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
