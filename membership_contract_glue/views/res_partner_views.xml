<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record
        id="action_create_membership_contract_from_partner"
        model="ir.actions.act_window"
    >
        <field name="name">Create Membership Contract</field>
        <field name="res_model">contract.contract</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="contract.contract_contract_customer_form_view" />
        <field name="target">new</field>
        <field
            name="context"
        >{'default_partner_id': active_id, 'default_invoice_partner_id': active_id, 'default_contract_type': 'sale', 'default_is_membership_contract': True, 'create_membership_contract_from_partner': True, 'auto_invoice_membership_contract_on_save': True}</field>
    </record>

    <record id="view_partner_form_membership_contract_controls" model="ir.ui.view">
        <field name="name">res.partner.form.membership.contract.controls</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="membership_extension.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='member_lines']" position="after">
                <group
                    string="Membership Contracts"
                    groups="membership_contract_glue.group_membership_administrator"
                >
                    <button
                        name="%(membership_contract_glue.action_create_membership_contract_from_partner)d"
                        type="action"
                        string="Create Membership Contract"
                        class="oe_highlight"
                    />
                    <field name="contract_ids" context="{'default_contract_type': 'sale'}">
                        <list create="0" delete="0" edit="0" open_form_view="1">
                            <field name="name" />
                            <field name="is_membership_contract" optional="show" />
                            <field name="company_id" />
                            <field name="date_start" optional="show" />
                            <field name="date_end" optional="show" />
                            <field name="recurring_next_date" string="Next Invoice" />
                            <field name="invoice_count" optional="show" />
                            <field name="active" optional="show" />
                        </list>
                    </field>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
