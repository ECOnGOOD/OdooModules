msgid "Number of Employees"
msgstr "Anzahl der Mitarbeitenden"

msgid "Number of Inhabitants"
msgstr "Anzahl der Einwohner"

msgid "ECOnGOOD OU"
msgstr "ECOnGOOD OE"

msgid "Enable this for ECOnGOOD organizational units such as national, regional, local chapter, or hub records."
msgstr "Aktivieren Sie dies fuer ECOnGOOD-Organisationseinheiten wie nationale, regionale, Local-Chapter- oder Hub-Datensaetze."

msgid "Organization Kind"
msgstr "Organisationsart"

msgid "OU Type"
msgstr "OE-Typ"

msgid "Nonprofit Status"
msgstr "Gemeinnuetzigkeitsstatus"

msgid "Unknown"
msgstr "Unbekannt"

msgid "Confirmed nonprofit"
msgstr "Gemeinnuetzig bestaetigt"

msgid "Not nonprofit"
msgstr "Nicht gemeinnuetzig"

msgid "Code of Conduct Signed On"
msgstr "Verhaltenskodex unterzeichnet am"

msgid "Privacy Agreement Signed On"
msgstr "Datenschutzvereinbarung unterzeichnet am"

msgid "ECOnGOOD Email Address"
msgstr "ECOnGOOD-E-Mail-Adresse"

msgid "Legacy ID SmartWe"
msgstr "Legacy-ID SmartWe"

msgid "Legacy ID Formidable"
msgstr "Legacy-ID Formidable"

msgid "Letter Salutation"
msgstr "Briefanrede"

msgid "Socials"
msgstr "Soziale Netzwerke"

msgid "Employee count (FTE)."
msgstr "Anzahl der Mitarbeitenden (VZAE)."

msgid "Population count if this partner represents a region or commune."
msgstr "Einwohnerzahl, falls dieser Kontakt eine Region oder Gemeinde darstellt."

msgid "Number of Employees cannot be negative."
msgstr "Die Anzahl der Mitarbeitenden darf nicht negativ sein."

msgid "Number of Inhabitants cannot be negative."
msgstr "Die Anzahl der Einwohner darf nicht negativ sein."

msgid "Code of Conduct Signed On cannot be in the future."
msgstr "Das Datum "Verhaltenskodex unterzeichnet am" darf nicht in der Zukunft liegen."

msgid "Privacy Agreement Signed On cannot be in the future."
msgstr "Das Datum "Datenschutzvereinbarung unterzeichnet am" darf nicht in der Zukunft liegen."

msgid "ECOnGOOD Email Address is not a valid email."
msgstr "Die ECOnGOOD-E-Mail-Adresse ist keine gueltige E-Mail."

msgid "ECOnGOOD OU, Organization Kind, and OU Type can only be set on company contacts."
msgstr "ECOnGOOD OE, Organisationsart und OE-Typ duerfen nur bei Firmenkontakten gesetzt werden."

msgid "Organization Kind must be empty when ECOnGOOD OU is enabled."
msgstr "Die Organisationsart muss leer sein, wenn ECOnGOOD OE aktiviert ist."

msgid "OU Type requires ECOnGOOD OU to be enabled."
msgstr "Der OE-Typ erfordert eine aktivierte ECOnGOOD OE."

msgid "Details &amp; Legal"
msgstr "Details &amp; Rechtliches"

msgid "Demographics"
msgstr "Demografie"

msgid "Legal Agreements &amp; Account"
msgstr "Rechtliche Vereinbarungen &amp; Konto"
