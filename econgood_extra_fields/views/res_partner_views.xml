<odoo>
    <record id="view_partner_form_econgood_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.econgood.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!--Hide personal information page since its data is used in Demographics-->
            <xpath expr="//page[@name='personal_information_page']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='partner_company_type_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//div[field[@name='current_membership_number_display']]" position="after">
                <field name="x_is_econgood_ou" invisible="not is_company"/>
                <field name="x_ou_type_id" invisible="not is_company or not x_is_econgood_ou"/>
                <field name="x_organization_kind_id" invisible="not is_company or x_is_econgood_ou"/>
                <field name="partner_company_type_id" invisible="not is_company"/>
                <field name="x_nonprofit_status" invisible="not is_company"/>
            </xpath>

            <xpath expr="//field[@name='website']" position="after">
                <field name="x_socials"/>
            </xpath>

            <xpath expr="//field[@name='title']" position="after">
                <field name="x_letter_salutation"/>
            </xpath>

            <page name="internal_notes" position="inside">
                <group>
                    <group name="import_notes" string="Import Notes">
                        <field name="x_legacy_id_smartwe"/>
                        <field name="x_legacy_id_formidable"/>
                    </group>
                </group>
            </page>

            <xpath expr="//notebook" position="inside">
                <page string="Details &amp; Legal">
                    <group>
                        <group string="Demographics">
                            <field name="gender" invisible="is_company"/>
                            <field name="birthdate_date" invisible="is_company"/>
                            <field name="age" invisible="not birthdate_date"/>

                            <field name="x_employee_count" invisible="not is_company"/>
                            <field name="x_inhabitant_count" invisible="not is_company"/>
                        </group>

                        <group string="Legal Agreements &amp; Account">
                            <field name="x_email_econgood" widget="email"/>
                            <field name="x_code_of_conduct_signed_date"/>
                            <field name="x_privacy_agreement_signed_date"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
